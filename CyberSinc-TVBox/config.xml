<?xml version='1.0' encoding='utf-8'?>
<widget id="com.cybersinc.usbstream.receiver" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>CyberSinc Receiver</name>
    <description>Ultra-low latency game mirroring receiver over USB.</description>
    <author email="dev@example.com" href="http://example.com">CyberSinc Team</author>
    <content src="index.html" />
    
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />

    <preference name="Orientation" value="landscape" />

    <platform name="android">
        <preference name="AndroidXEnabled" value="true" />
        <preference name="KeepRunning" value="true" />
        
        <config-file target="AndroidManifest.xml" parent="/*">
            <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
            <uses-permission android:name="android.permission.USB_PERMISSION" />
        </config-file>

        <config-file target="AndroidManifest.xml" parent="/manifest/application/activity">
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_ACCESSORY_ATTACHED" />
            </intent-filter>
            <meta-data android:name="android.hardware.usb.action.USB_ACCESSORY_ATTACHED" android:resource="@xml/usb_accessory_filter" />
        </config-file>
    </platform>
</widget>
